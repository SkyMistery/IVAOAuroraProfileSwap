@namespace AuroraProfileSwapper.Web.Pages
@using System.IO.Compression
@inject IJSRuntime JS

<div class="page" tabindex="0" @onkeydown="OnKey">
    <header class="app-header">
        <div class="header-bar">
            <div class="app-title">
                <img class="app-logo" src="@(_isDark ? "img/it-symbol-white.svg" : "img/it-symbol.svg")" alt="IVAO Italia" />
                <h1>Aurora Profile Swapper</h1>
            </div>
            <div class="header-controls">
                <button class="ctrl-btn" title="@(_isDark ? T("themeToTitleLight") : T("themeToTitle"))"
                        @onclick="ToggleTheme">
                    @(_isDark ? "☀️" : "🌙")
                </button>
                <div class="lang-switch">
                    <button class="lang-opt @(_lang == AppLang.It ? "active" : "")"
                            @onclick="@(() => SetLang(AppLang.It))">IT</button>
                    <span class="lang-sep">/</span>
                    <button class="lang-opt @(_lang == AppLang.En ? "active" : "")"
                            @onclick="@(() => SetLang(AppLang.En))">EN</button>
                </div>
            </div>
        </div>
        <p>@((MarkupString)T("intro"))</p>
    </header>

    <div class="columns">
        <div class="card">
            <h4>@T("sourceTitle")</h4>
            <p class="hint">@((MarkupString)T("sourceHint"))</p>
            @if (_source is not null)
            {
                <div class="file-loaded">
                    <span class="file-check">✓</span>
                    <div class="file-info">
                        <span class="file-name">@_sourceName</span>
                        <span class="file-meta">@T("secCount", _source.SectionNames.Count())</span>
                    </div>
                    <button class="btn-reset" title="@T("changeTitle")" @onclick="ResetSource">@T("change")</button>
                </div>
            }
            else
            {
                <label class="file-drop @(_sourceDragOver ? "dragover" : "")"
                       @ondragenter="() => _sourceDragOver = true"
                       @ondragleave="() => _sourceDragOver = false"
                       @ondrop="() => _sourceDragOver = false">
                    <span class="drop-hint">@((MarkupString)T("dropSource"))</span>
                    <InputFile OnChange="LoadSource" accept=".cpr" />
                </label>
            }
        </div>

        <div class="card">
            <div class="card-head">
                <h4>@T("destTitle")@(_dests.Count > 0 ? $" ({_dests.Count})" : "")</h4>
                @if (_dests.Count > 1)
                {
                    <button class="link-btn" @onclick="ClearAllDests">@T("clearAllDests")</button>
                }
            </div>
            <p class="hint">@((MarkupString)T("destHint"))</p>

            @if (_dests.Count > 0)
            {
                <ul class="dest-list">
                    @foreach (var d in _dests)
                    {
                        <li class="file-loaded" @key="d.Id">
                            <span class="file-check">✓</span>
                            <div class="file-info">
                                <span class="file-name">@d.Name</span>
                                <span class="file-meta">@T("secCount", d.Profile.SectionNames.Count())</span>
                            </div>
                            <button class="btn-reset" title="@T("removeTitle")"
                                    @onclick="@(() => RemoveDest(d.Id))">@T("remove")</button>
                        </li>
                    }
                </ul>
            }

            <label class="file-drop @(_destDragOver ? "dragover" : "")"
                   @ondragenter="() => _destDragOver = true"
                   @ondragleave="() => _destDragOver = false"
                   @ondrop="() => _destDragOver = false">
                <span class="drop-hint">@((MarkupString)T("dropDest"))</span>
                @* @key forces a fresh <input> after each load/remove so the next drop
                   always fires OnChange (Blazor reuses the element otherwise). *@
                <InputFile @key="_destInputKey" OnChange="LoadDests" accept=".cpr" multiple />
            </label>
        </div>
    </div>

    @if (_source is not null && _dests.Count > 0)
    {
        var warnings = BuildWarnings();
        @if (warnings.Count > 0)
        {
            <div class="warnings">
                <strong>@T("warningsTitle")</strong>
                <ul>
                    @foreach (var w in warnings)
                    {
                        <li>@w</li>
                    }
                </ul>
            </div>
        }

        <section class="sections">
            <h4>@T("sectionsTitle")</h4>
            <div class="sections-toolbar">
                <input class="section-search" type="search" placeholder="@T("searchPlaceholder")"
                       value="@_sectionFilter" @oninput="OnFilterInput"
                       @onkeydown:stopPropagation="true" />
                <button class="link-btn" @onclick="SelectAll">@T("selectAll")</button>
                <button class="link-btn" @onclick="ClearAll">@T("clearAll")</button>
                <span class="selected-count">@T("selectedCount", _selected.Count)</span>
            </div>

            <div class="section-grid">
                @foreach (var name in VisibleSectionNames())
                {
                    var srcSec = _source.FindSection(name)!;
                    var isNewAll = _dests.All(d => d.Profile.FindSection(name) is null);
                    var isSameAll = IsIdenticalInAll(name);
                    <label class="section-item @(_selected.Contains(name) ? "checked" : "")" title="@name">
                        <input type="checkbox"
                               checked="@_selected.Contains(name)"
                               @onchange="@(e => Toggle(name, (bool)e.Value!))" />
                        <span class="section-name @(isNewAll ? "only-source" : "")">@name</span>
                        <span class="section-tags">
                            @if (isNewAll)
                            {
                                <span class="badge-new" title="@T("newBadgeTitle")">NEW</span>
                            }
                            else if (isSameAll)
                            {
                                <span class="badge-same" title="@T("badgeSameTitle")">@T("badgeSame")</span>
                            }
                            <span class="section-meta">@T("secMeta", SectionLineCount(srcSec))</span>
                        </span>
                    </label>
                }
                @if (!VisibleSectionNames().Any())
                {
                    <span class="no-match">@T("noMatch")</span>
                }
            </div>

            @if (_selected.Count > 0)
            {
                <div class="preview">
                    <h5>@T("previewTitle")</h5>
                    <p class="hint">@((MarkupString)T("previewHint", _dests.Count))</p>
                    @foreach (var name in _sourceSectionNames.Where(_selected.Contains))
                    {
                        var srcSection = _source.FindSection(name)!;
                        <div class="preview-block">
                            <div class="preview-title">[@name]</div>
                            @foreach (var d in _dests)
                            {
                                var dstSection = d.Profile.FindSection(name);
                                var identical = dstSection is not null && dstSection.RawText == srcSection.RawText;
                                <details class="diff-dest" open="@(_dests.Count == 1)">
                                    <summary>
                                        <span class="diff-dest-name">@d.Name</span>
                                        @if (dstSection is null)
                                        {
                                            <span class="badge-new">NEW</span>
                                        }
                                        else if (identical)
                                        {
                                            <span class="badge-same">@T("badgeSame")</span>
                                        }
                                    </summary>
                                    @if (identical)
                                    {
                                        <div class="diff-identical">@T("identicalNoChange")</div>
                                    }
                                    else
                                    {
                                        IEnumerable<string> from = dstSection is null ? Array.Empty<string>() : dstSection.Lines;
                                        <div class="diff">
                                            @foreach (var dl in LineDiff.Diff(from, srcSection.Lines))
                                            {
                                                <div class="diff-line @DiffClass(dl.Kind)">@DiffPrefix(dl.Kind)@dl.Text</div>
                                            }
                                        </div>
                                    }
                                </details>
                            }
                        </div>
                    }
                </div>
            }

            <div class="actions">
                <button class="btn-primary" disabled="@(_selected.Count == 0 || _busy)" @onclick="DoSwap">
                    @if (_busy)
                    {
                        <span class="spinner"></span> <span>@T("busy")</span>
                    }
                    else
                    {
                        @T("swapBtn", _dests.Count)
                    }
                </button>
                <span class="selected-count">@T("outputInfo", _dests.Count)</span>
            </div>
        </section>
    }

    @if (_status is not null)
    {
        <div id="status" class="status @_statusKind">
            @_status
            @if (_details.Count > 0)
            {
                <ul>
                    @foreach (var d in _details)
                    {
                        <li>@d</li>
                    }
                </ul>
            }
        </div>
    }

    <footer class="app-footer">
        @T("footer")
        <a href="https://brand.ivao.aero" target="_blank" rel="noopener">@T("footerBrand")</a>.
    </footer>
</div>

@code {
    private sealed class DestProfile
    {
        public Guid Id { get; } = Guid.NewGuid();
        public required CprProfile Profile { get; init; }
        public required string Name { get; init; }
    }

    private CprProfile? _source;
    private string? _sourceName;
    private readonly List<DestProfile> _dests = new();

    private bool _sourceDragOver;
    private bool _destDragOver;
    private List<string> _sourceSectionNames = new();
    private readonly HashSet<string> _selected = new(StringComparer.OrdinalIgnoreCase);
    private string _sectionFilter = "";
    private int _destInputKey;

    private string? _status;
    private string _statusKind = "ok";
    private readonly List<string> _details = new();
    private bool _busy;

    private AppLang _lang = AppLang.It;
    private bool _isDark;

    // Cap uploads at a sane size for these text profiles (~1 MB is already huge for .cpr).
    private const long MaxFileBytes = 4 * 1024 * 1024;

    // Shorthand for localized lookups in markup.
    private string T(string key) => Loc.T(_lang, key);
    private string T(string key, params object[] args) => Loc.T(_lang, key, args);

    // --- section helpers -----------------------------------------------------

    private IEnumerable<string> VisibleSectionNames() =>
        string.IsNullOrWhiteSpace(_sectionFilter)
            ? _sourceSectionNames
            : _sourceSectionNames.Where(n => n.Contains(_sectionFilter, StringComparison.OrdinalIgnoreCase));

    // Line count excluding the "[NAME]" header line.
    private static int SectionLineCount(CprSection s) => s.Lines.Count - (s.Name is null ? 0 : 1);

    private bool IsIdenticalInAll(string name)
    {
        var src = _source!.FindSection(name);
        if (src is null) return false;
        return _dests.All(d => d.Profile.FindSection(name) is { } dst && dst.RawText == src.RawText);
    }

    private static string DiffClass(DiffKind k) => k switch
    {
        DiffKind.Added => "diff-add",
        DiffKind.Removed => "diff-del",
        _ => "diff-eq"
    };

    private static string DiffPrefix(DiffKind k) => k switch
    {
        DiffKind.Added => "+ ",
        DiffKind.Removed => "- ",
        _ => "  "
    };

    private List<string> BuildWarnings()
    {
        var list = new List<string>();
        if (_source is null) return list;

        var srcText = _source.Serialize();
        foreach (var d in _dests)
        {
            if (string.Equals(d.Name, _sourceName, StringComparison.OrdinalIgnoreCase))
                list.Add(T("warnSameName", d.Name));
            if (d.Profile.Serialize() == srcText)
                list.Add(T("warnSameContent", d.Name));
        }

        // Duplicate destinations (same name + identical content).
        foreach (var grp in _dests
            .GroupBy(d => (d.Name, d.Profile.Serialize()))
            .Where(g => g.Count() > 1))
        {
            list.Add(T("warnDuplicate", grp.Key.Name));
        }

        return list;
    }

    // --- preferences ---------------------------------------------------------

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Restore persisted language + theme (theme's <html> attribute is already set
        // by the inline boot script; here we only sync our own state + button labels).
        var lang = await JS.InvokeAsync<string>("appPrefs.getLang");
        var theme = await JS.InvokeAsync<string>("appPrefs.getTheme");
        var newLang = string.Equals(lang, "en", StringComparison.OrdinalIgnoreCase) ? AppLang.En : AppLang.It;
        var newDark = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);
        if (newLang != _lang || newDark != _isDark)
        {
            _lang = newLang;
            _isDark = newDark;
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("appPrefs.setTheme", _isDark ? "dark" : "light");
    }

    private async Task SetLang(AppLang lang)
    {
        if (_lang == lang) return;
        _lang = lang;
        await JS.InvokeVoidAsync("appPrefs.setLang", lang == AppLang.En ? "en" : "it");
    }

    // --- keyboard shortcuts --------------------------------------------------

    private async Task OnKey(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter" when _source is not null && _dests.Count > 0 && _selected.Count > 0 && !_busy:
                await DoSwap();
                break;
            case "Escape":
                ClearAll();
                break;
        }
    }

    // --- file loading --------------------------------------------------------

    private async Task LoadSource(InputFileChangeEventArgs e)
    {
        ResetStatus();
        var file = e.File;
        try
        {
            _source = await ReadProfile(file);
            _sourceName = file.Name;
            RefreshSectionList();
        }
        catch (IOException)
        {
            SetStatus("err", T("errTooBig", file.Name, MaxFileBytes / (1024 * 1024)));
        }
        catch (Exception ex)
        {
            SetStatus("err", T("errRead", file.Name, ex.Message));
        }
    }

    private async Task LoadDests(InputFileChangeEventArgs e)
    {
        ResetStatus();
        foreach (var file in e.GetMultipleFiles(maximumFileCount: 50))
        {
            try
            {
                var profile = await ReadProfile(file);
                _dests.Add(new DestProfile { Profile = profile, Name = file.Name });
            }
            catch (IOException)
            {
                SetStatus("err", T("errTooBig", file.Name, MaxFileBytes / (1024 * 1024)));
            }
            catch (Exception ex)
            {
                SetStatus("err", T("errRead", file.Name, ex.Message));
            }
        }
        _destInputKey++;
    }

    private static async Task<CprProfile> ReadProfile(IBrowserFile file)
    {
        using var stream = file.OpenReadStream(MaxFileBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return CprProfile.Load(ms.ToArray());
    }

    private void ResetSource()
    {
        ResetStatus();
        _source = null;
        _sourceName = null;
        _sourceSectionNames.Clear();
        _selected.Clear();
        _sectionFilter = "";
    }

    private void RemoveDest(Guid id)
    {
        ResetStatus();
        _dests.RemoveAll(d => d.Id == id);
        _destInputKey++;
    }

    private void ClearAllDests()
    {
        ResetStatus();
        _dests.Clear();
        _destInputKey++;
    }

    private void RefreshSectionList()
    {
        if (_source is null) return;
        _sourceSectionNames = _source.SectionNames.Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        _selected.RemoveWhere(s => !_sourceSectionNames.Contains(s, StringComparer.OrdinalIgnoreCase));
    }

    private void OnFilterInput(ChangeEventArgs e) => _sectionFilter = e.Value?.ToString() ?? "";

    private void Toggle(string name, bool on)
    {
        if (on) _selected.Add(name); else _selected.Remove(name);
    }

    // Select all currently-visible (filtered) sections.
    private void SelectAll()
    {
        foreach (var n in VisibleSectionNames()) _selected.Add(n);
    }

    private void ClearAll() => _selected.Clear();

    // --- swap ---------------------------------------------------------------

    private async Task DoSwap()
    {
        ResetStatus();
        if (_source is null || _dests.Count == 0 || _selected.Count == 0) return;

        var names = _sourceSectionNames.Where(_selected.Contains).ToList();

        _busy = true;
        StateHasChanged();
        await Task.Yield(); // let the spinner render before the (synchronous) zip work

        try
        {
            _details.Clear();
            int totalAppended = 0;
            var usedNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            using var zipMs = new MemoryStream();
            using (var zip = new ZipArchive(zipMs, ZipArchiveMode.Create, leaveOpen: true))
            {
                foreach (var d in _dests)
                {
                    var result = ProfileSwapper.SwapSections(d.Profile, _source, names, out var outcomes);

                    // Avoid clobbering entries when two destinations share a filename.
                    var entryName = UniqueEntryName(d.Name, usedNames);
                    var entry = zip.CreateEntry(entryName, CompressionLevel.Optimal);
                    using (var es = entry.Open())
                    {
                        var bytes = result.ToBytes();
                        es.Write(bytes, 0, bytes.Length);
                    }

                    var replaced = outcomes.Count(o => o.WasReplaced);
                    var appended = outcomes.Count(o => !o.WasReplaced);
                    totalAppended += appended;
                    _details.Add(T("detailLine", entryName, outcomes.Count, replaced, appended));
                }
            }

            var zipName = $"profili-aggiornati-{DateTime.Now:yyyyMMdd-HHmmss}.zip";
            var zipBase64 = Convert.ToBase64String(zipMs.ToArray());
            await JS.InvokeVoidAsync("downloadFileFromBase64", zipName, zipBase64);

            SetStatus(totalAppended > 0 ? "warn" : "ok", T("done", names.Count, _dests.Count, zipName));
        }
        catch (SectionNotFoundException ex)
        {
            SetStatus("err", T("errSectionMissing", ex.SectionName));
        }
        catch (Exception ex)
        {
            SetStatus("err", T("errSwap", ex.Message));
        }
        finally
        {
            _busy = false;
        }

        await JS.InvokeVoidAsync("appPrefs.scrollToId", "status");
    }

    // Make a zip-safe, non-colliding entry name (append " (2)", " (3)"… on duplicates).
    private static string UniqueEntryName(string name, HashSet<string> used)
    {
        if (used.Add(name)) return name;
        var ext = Path.GetExtension(name);
        var stem = Path.GetFileNameWithoutExtension(name);
        for (int i = 2; ; i++)
        {
            var candidate = $"{stem} ({i}){ext}";
            if (used.Add(candidate)) return candidate;
        }
    }

    private void SetStatus(string kind, string message)
    {
        _statusKind = kind;
        _status = message;
    }

    private void ResetStatus()
    {
        _status = null;
        _statusKind = "ok";
        _details.Clear();
    }
}
